{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HIL GUI",
  "version": "0.1.0",
  "identifier": "com.urielcontardi.hilgui",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run frontend:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HIL GUI",
        "width": 1360,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
