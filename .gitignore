.vscode

# GHDL generated files
*.cf
*.ghw
*.vcd

# Build artifacts
build/
*.code-workspace

# Python / cocotb
__pycache__/
*.pyc
.venv/
sim_build/
results.xml
verification/cocotb/results.xml

# Compiled NVC UNISIM library (binary, platform-specific — run 'make setup-unisim' to rebuild)
verification/cocotb/libs/

# NVC compiled work library (binary simulation artifacts — regenerated on each simulation run)
work/

# Generated reports (CSV data and HTML — regenerated by scripts)
verification/cocotb/reports/*.csv
verification/cocotb/reports/*.html

# Vivado logs (generated wherever vivado is launched)
vivado.jou
vivado.log
vivado_*.jou
vivado_*.log
*.backup.jou
*.backup.log
.Xil/

# Vivado generated project artifacts (see also syn/.gitignore)
syn/**/*.cache/
syn/**/*.gen/
syn/**/*.hw/
syn/**/*.ip_user_files/
syn/**/*.runs/
syn/**/*.srcs/
syn/**/*.sim/
syn/**/*.xpr