/include/ "system-conf.dtsi"
/ {
};

/* EBAZ4205: IC-Plus IP101GA PHY via EMIO/PL GMII, MDIO address 1 */
&gem0 {
	phy-handle = <&phy0>;
	mdio {
		#address-cells = <1>;
		#size-cells = <0>;
		phy0: ethernet-phy@1 {
			compatible = "ethernet-phy-ieee802.3-c22";
			device_type = "ethernet-phy";
			reg = <1>;
		};
	};
};
